# IMAP mailbox settings
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your_email@example.com
IMAP_PASS=your_app_password
IMAP_FOLDER=INBOX
IMAP_SEARCH=UNSEEN

# Anthropic settings
ANTHROPIC_API_KEY=sk-ant-api03-xxxx
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_MAX_TOKENS=2048

# Gmail OAuth Web (for /gmail-do page)
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
# Must exactly match the OAuth redirect URI configured in Google Cloud Console
# Local example:
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/gmail/auth/callback

# Extractor runtime settings
EMAIL_EXTRACT_POLL_SECONDS=60
EMAIL_EXTRACT_MARK_SEEN=true
EMAIL_EXTRACT_OUTPUT_DIR=data/email_extractions
EMAIL_EXTRACT_STATE_FILE=data/email_extractions/processed_uids.json
